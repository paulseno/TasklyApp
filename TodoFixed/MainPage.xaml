<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDo_App.MainPage"
             Title="ToDo"
             BackgroundColor="#2b2539">

    <Grid RowDefinitions="*,Auto" Padding="16,10,16,10">

        <VerticalStackLayout Grid.Row="0" Spacing="8">

            <Label Text="Task List"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   Margin="0,10,0,4"/>

            <Label x:Name="EmptyLabel"
                   Text="No tasks yet. Tap + to add one!"
                   IsVisible="True"
                   FontSize="15"
                   HorizontalTextAlignment="Center"
                   TextColor="#aaa"/>

            <ListView x:Name="todoLV"
                      HasUnevenRows="True"
                      SeparatorVisibility="None"
                      BackgroundColor="Transparent"
                      ItemTapped="todoLV_ItemTapped">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Border Margin="0,4" Padding="14,10" BackgroundColor="#3a3250">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,Auto,Auto">

                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label Text="{Binding Title}"
                                               FontSize="16" FontAttributes="Bold"
                                               TextColor="White"/>
                                        <Label Text="{Binding Detail}"
                                               FontSize="13" TextColor="#bbb"/>
                                    </VerticalStackLayout>

                                    <!-- Quick Complete -->
                                    <Button Grid.Column="1"
                                            Text="&#x2714;"
                                            FontSize="18"
                                            BackgroundColor="Transparent"
                                            TextColor="#a5d6a7"
                                            WidthRequest="44"
                                            HeightRequest="44"
                                            Padding="0"
                                            ClassId="{Binding Id}"
                                            Clicked="QuickCompleteItem"/>

                                    <!-- Delete -->
                                    <Button Grid.Column="2"
                                            Text="&#x1F5D1;"
                                            FontSize="18"
                                            BackgroundColor="Transparent"
                                            TextColor="#f88"
                                            WidthRequest="44"
                                            HeightRequest="44"
                                            Padding="0"
                                            ClassId="{Binding Id}"
                                            Clicked="DeleteToDoItem"/>

                                </Grid>
                            </Border>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </VerticalStackLayout>

        <!-- FAB -->
        <Button Grid.Row="1"
                Text="+"
                FontSize="24" FontAttributes="Bold"
                TextColor="#2b2539"
                Background="#ccc2ff"
                HeightRequest="58" WidthRequest="58"
                CornerRadius="29"
                Padding="0"
                HorizontalOptions="End"
                Margin="0,6,6,6"
                Clicked="OpenAddPage"/>

    </Grid>
</ContentPage>