<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDo_App.EditPage"
             Title="Edit Task" BackgroundColor="#2b2539">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Spacing="16" Padding="20">
                <Label Text="Edit Task" FontSize="22" FontAttributes="Bold"
                       TextColor="White" HorizontalTextAlignment="Center" Margin="0,16,0,8"/>
                <Label Text="Title" TextColor="#ccc2ff" FontSize="13"/>
                <Border Stroke="#555" StrokeThickness="1" Background="#3a3250" StrokeShape="RoundRectangle 8">
                    <Entry x:Name="TitleEntry" TextColor="White" PlaceholderColor="#aaa"
                           Placeholder="Task title" MaxLength="80" Margin="15,0"/>
                </Border>
                <Label Text="Details" TextColor="#ccc2ff" FontSize="13"/>
                <Border Stroke="#555" StrokeThickness="1" Background="#3a3250" StrokeShape="RoundRectangle 8">
                    <Editor x:Name="DetailsEditor" TextColor="White" PlaceholderColor="#aaa"
                            Placeholder="Task details" HeightRequest="120" MaxLength="300" Margin="10,5"/>
                </Border>
                <!-- Update (purple) -->
                <Button Text="Update" Background="#ccc2ff" TextColor="#2b2539"
                        FontAttributes="Bold" CornerRadius="10" HeightRequest="50"
                        Clicked="OnUpdateClicked"/>
                <!-- Complete / Incomplete (green or gray) -->
                <Button x:Name="CompleteBtn"
                        Text="Complete" Background="#4CAF50" TextColor="White"
                        FontAttributes="Bold" CornerRadius="10" HeightRequest="50"
                        Clicked="OnCompleteToggleClicked"/>
                <!-- Delete (pink-red) -->
                <Button Text="Delete" Background="#f48fb1" TextColor="#2b2539"
                        FontAttributes="Bold" CornerRadius="10" HeightRequest="50"
                        Clicked="OnDeleteClicked"/>
            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>