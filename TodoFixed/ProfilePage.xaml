<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDo_App.ProfilePage"
             Title="Profile" BackgroundColor="#2b2539">
    <VerticalStackLayout Spacing="16" Padding="30" VerticalOptions="Center">

        <Border StrokeThickness="2" Stroke="#ccc2ff" StrokeShape="RoundRectangle 60"
                HeightRequest="120" WidthRequest="120" HorizontalOptions="Center">
            <Image Source="todo_logo.png" HeightRequest="110" WidthRequest="110" Aspect="AspectFill"/>
        </Border>

        <Label x:Name="UsernameLabel" Text="—"
               FontSize="24" FontAttributes="Bold"
               TextColor="White" HorizontalTextAlignment="Center"/>

        <Label x:Name="EmailLabel" Text="—"
               FontSize="15" TextColor="#ccc2ff"
               HorizontalTextAlignment="Center"/>

        <BoxView HeightRequest="1" Color="#444" Margin="0,10"/>

        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="4">
            <Label Grid.Column="0" Text="Tasks Pending" TextColor="#aaa"
                   FontSize="13" HorizontalTextAlignment="Center"/>
            <Label Grid.Column="1" Text="Tasks Done" TextColor="#aaa"
                   FontSize="13" HorizontalTextAlignment="Center"/>
            <Label x:Name="PendingCount" Grid.Row="1" Grid.Column="0"
                   Text="0" FontSize="28" FontAttributes="Bold"
                   TextColor="White" HorizontalTextAlignment="Center"/>
            <Label x:Name="DoneCount" Grid.Row="1" Grid.Column="1"
                   Text="0" FontSize="28" FontAttributes="Bold"
                   TextColor="#a5d6a7" HorizontalTextAlignment="Center"/>
        </Grid>

        <BoxView HeightRequest="1" Color="#444" Margin="0,10"/>

        <Button Text="Sign Out" Background="#555" TextColor="White"
                CornerRadius="10" HeightRequest="50"
                FontAttributes="Bold" Clicked="OnSignOutClicked"/>
    </VerticalStackLayout>
</ContentPage>