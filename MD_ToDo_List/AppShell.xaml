<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MD_ToDo_List.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MD_ToDo_List"
    xmlns:pages="clr-namespace:MD_ToDo_List.Pages"
    Title="MD_ToDo_List">

    <!-- Define routes -->
    <ShellContent
        Title="Sign In"
        ContentTemplate="{DataTemplate pages:SignInPage}"
        Route="signin" />

    <ShellContent
        Title="Sign Up"
        ContentTemplate="{DataTemplate pages:SignUpPage}"
        Route="signup" />

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="mainpage" />

</Shell>
